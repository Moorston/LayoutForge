# ════════════════════════════════════════════════════════════════════════
#  Layout Replicator — Environment Configuration
#  Copy this file to .env.local and fill in the keys you want to use.
#  .env.local is listed in .gitignore and will NEVER be committed.
# ════════════════════════════════════════════════════════════════════════

# ── Active Provider ───────────────────────────────────────────────────────────
# Which AI provider to use. Options:
#   openai | anthropic | google | deepseek | qwen | zhipu | groq | mimo | custom
AI_PROVIDER=mimo

# ── Model Overrides (optional) ────────────────────────────────────────────────
# Leave empty to use the provider's default model.
AI_MODEL_TEXT=
AI_MODEL_VISION=

# ── Generic API Base URL Override (optional) ─────────────────────────────────
# Set this to override the default API base URL for the active provider.
# Useful for custom gateways, proxies, or self-hosted endpoints.
# Example: AI_API_BASE_URL=https://my-proxy.example.com/v1
AI_API_BASE_URL=

# ── API Keys — add the key for whichever provider(s) you want to use ──────────

# OpenAI  →  https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic  →  https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google Gemini  →  https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# DeepSeek  →  https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# 阿里云通义千问  →  https://bailian.console.aliyun.com/
QWEN_API_KEY=

# 智谱 GLM  →  https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=

# Groq  →  https://console.groq.com/keys
GROQ_API_KEY=

# Xiaomi MiMo  →  https://mimo-v2.com/settings/api-keys
MIMO_API_KEY=

# ── MiMo Base URL (required for MiMo provider) ────────────────────────────────
# The API gateway URL for MiMo. Common options:
#   https://token-plan-sgp.xiaomimimo.com/v1  (Singapore — default)
#   https://token-plan-cn.xiaomimimo.com/v1   (China)
# If not set, falls back to AI_API_BASE_URL, then to the Singapore default.
MIMO_API_BASE_URL=

# ── Custom OpenAI-compatible Endpoint ─────────────────────────────────────────
# Set AI_PROVIDER=custom above to use these.
AI_CUSTOM_BASE_URL=
AI_CUSTOM_API_KEY=
# Override model name for custom endpoint
AI_CUSTOM_MODEL=
